# Copy to /etc/firecracker/chisel-check.env on a separate checker host.

# Chisel endpoint exposed by the host.
CHISEL_CHECK_URL=https://relay.example.com/chisel
CHISEL_CHECK_AUTH=replace-user:replace-secret

# Remote endpoints inside the Firecracker bridge network.
CHISEL_CHECK_KAFKA_REMOTE=172.30.0.10:9092
CHISEL_CHECK_RELAY_REMOTE=172.30.0.20:8080

# Local ports on checker host for temporary tunnel forwards.
CHISEL_CHECK_LOCAL_KAFKA_PORT=19092
CHISEL_CHECK_LOCAL_RELAY_PORT=18080

# Enable/disable checks.
CHISEL_CHECK_ENABLE_KAFKA=true
CHISEL_CHECK_ENABLE_RELAY=true

# Relay check expectation.
CHISEL_CHECK_RELAY_HEALTH_PATH=/health
CHISEL_CHECK_EXPECT_RELAY_CODE=200

# Timeouts.
CHISEL_CHECK_CONNECT_WAIT_SECONDS=8
CHISEL_CHECK_TIMEOUT_SECONDS=10

# Optional log override.
# CHISEL_CHECK_LOG_FILE=/var/log/firecracker/external-chisel-check.log
