# Copy to /etc/firecracker/alerts.env and customize.

# Optional webhook endpoint for push alerts.
# ALERT_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# Optional bearer token if your webhook endpoint requires auth.
# ALERT_WEBHOOK_BEARER_TOKEN="replace-me"

# Optional email recipient. Requires sendmail or mail on host.
# ALERT_EMAIL_TO="ops@example.com"
# ALERT_EMAIL_FROM="firecracker-alerts@example.com"

# Alert de-dup window in seconds per alert event key.
ALERT_COOLDOWN_SECONDS=300

# Optional host label for alert payloads/subjects.
# ALERT_HOST_LABEL="firecracker-prod"

# Optional overrides (usually keep defaults).
# ALERT_STATE_DIR="/var/lib/firecracker-watchdog"
# ALERT_LOG_FILE="/var/log/firecracker/alerts.log"
