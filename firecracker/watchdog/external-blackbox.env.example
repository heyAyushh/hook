# Copy to /etc/firecracker/external-blackbox.env on a separate checker host.

# Public entrypoint to validate from outside the Firecracker host.
BLACKBOX_BASE_URL=https://relay.example.com

# Expected status codes.
BLACKBOX_EXPECT_WEBHOOK_CODE=401
BLACKBOX_EXPECT_ROOT_CODE=200
BLACKBOX_TIMEOUT_SECONDS=8

# Optional log override.
# BLACKBOX_LOG_FILE=/var/log/firecracker/external-blackbox.log
