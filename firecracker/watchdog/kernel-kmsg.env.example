# Copy to /etc/firecracker/kernel-kmsg.env and customize.

# Primary output file. Script falls back to /var/tmp and /tmp if unwritable.
KMSG_LOG_FILE=/var/log/firecracker/kernel-kmsg.log

# Optional fallback list (colon-separated).
# KMSG_FALLBACK_LOG_FILES=/var/tmp/firecracker-watchdog/kernel-kmsg.log:/tmp/firecracker-watchdog/kernel-kmsg.log

# "tail" starts from new messages only; "all" dumps entire buffer at start.
KMSG_START_MODE=tail

# Log rotation size (bytes). 0 disables rotation.
KMSG_ROTATE_BYTES=268435456

# Flush/fsync controls for panic-safe persistence.
KMSG_FSYNC_EVERY_LINES=1
KMSG_FSYNC_MAX_SECONDS=1
